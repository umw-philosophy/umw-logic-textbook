    </part>

    <!--
      Part II — Categorical Logic (Venn-first)
      Mood and Figure de-emphasized in favor of Venn diagram method.
    -->
    <part xml:id="part-categorical">
      <title>Categorical Logic</title>
      <xi:include href="chapters/ch-categorical-propositions.ptx"/>
      <xi:include href="chapters/ch-categorical-syllogisms.ptx"/>
    </part>

    <!--
      Part III — Sentential Logic
      Copi notation. 18-rule natural deduction system. CP and IP taught but
      assessment problems solvable using only the 18 rules.
    -->
    <part xml:id="part-sentential">
      <title>Sentential Logic</title>
      <xi:include href="chapters/ch-symbolizing.ptx"/>
      <xi:include href="chapters/ch-truth-tables.ptx"/>
