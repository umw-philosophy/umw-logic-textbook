            <render_choice>
              <response_label ident="ch1-sec4-recognizing-arguments_q1_a0">
                <material><mattext texttype="text/plain">Explanation</mattext></material>
              </response_label>
              <response_label ident="ch1-sec4-recognizing-arguments_q1_a1">
                <material><mattext texttype="text/plain">Argument</mattext></material>
              </response_label>
              <response_label ident="ch1-sec4-recognizing-arguments_q1_a2">
                <material><mattext texttype="text/plain">Neither</mattext></material>
              </response_label>
              <response_label ident="ch1-sec4-recognizing-arguments_q1_a3">
                <material><mattext texttype="text/plain">Both, because all uses of &#x27;because&#x27; are arguments</mattext></material>
              </response_label>
