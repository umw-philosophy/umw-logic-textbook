              <response_label ident="ch1-sec4-recognizing-arguments_q13_a1">
                <material><mattext texttype="text/plain">How many commas does the passage contain?</mattext></material>
              </response_label>
              <response_label ident="ch1-sec4-recognizing-arguments_q13_a2">
                <material><mattext texttype="text/plain">Does the first sentence have more than ten words?</mattext></material>
              </response_label>
              <response_label ident="ch1-sec4-recognizing-arguments_q13_a3">
                <material><mattext texttype="text/plain">Can I ignore all sentences without indicator words?</mattext></material>
              </response_label>
