              </response_label>
              <response_label ident="ch1-sec4-recognizing-arguments_q3_a2">
                <material><mattext texttype="text/plain">treat the first sentence as the conclusion every time</mattext></material>
              </response_label>
              <response_label ident="ch1-sec4-recognizing-arguments_q3_a3">
