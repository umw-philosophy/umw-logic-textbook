  <assessment ident="assessment_34dda4d685a3476eb9d0c8ad3fd4a7b0" title="Chapter 1 Quiz 3: Premises and Conclusions">
    <qtimetadata>
      <qtimetadatafield><fieldlabel>cc_maxattempts</fieldlabel><fieldentry>unlimited</fieldentry></qtimetadatafield>
    </qtimetadata>
    <section ident="root_section">

      <item ident="q3_1" title="Question 1">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield>
            <qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material><mattext texttype="text/html">&lt;div&gt;Identify the conclusion: &lt;br&gt;&lt;br&gt;&lt;em&gt;The sidewalks are wet because it rained overnight.&lt;/em&gt;&lt;/div&gt;</mattext></material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="q3_1_a0">
                <material><mattext texttype="text/plain">The sidewalks are wet.</mattext></material>
              </response_label>
              <response_label ident="q3_1_a1">
                <material><mattext texttype="text/plain">It rained overnight.</mattext></material>
              </response_label>
              <response_label ident="q3_1_a2">
                <material><mattext texttype="text/plain">Because</mattext></material>
              </response_label>
              <response_label ident="q3_1_a3">
                <material><mattext texttype="text/plain">There is no argument here.</mattext></material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/></outcomes>
          <respcondition continue="No">
            <conditionvar><varequal respident="response1">q3_1_a0</varequal></conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
