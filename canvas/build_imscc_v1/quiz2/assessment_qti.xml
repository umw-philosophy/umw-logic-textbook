      <item ident="quiz2_q2" title="Question 3">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;Is the following sentence a statement? 'Universal basic income would make society fairer.'&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="quiz2_q2_ans0">
                <material>
                  <mattext texttype="text/plain">Yes, it is a statement.</mattext>
                </material>
              </response_label>
              <response_label ident="quiz2_q2_ans1">
                <material>
                  <mattext texttype="text/plain">No, because it is an opinion.</mattext>
                </material>
              </response_label>
              <response_label ident="quiz2_q2_ans2">
                <material>
                  <mattext texttype="text/plain">No, because there is no consensus.</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">quiz2_q2_ans0</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="quiz2_q3" title="Question 4">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;What is wrong with this classification: 'Factory farming is wrong' is not a statement because it is an opinion.&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="quiz2_q3_ans0">
                <material>
                  <mattext texttype="text/plain">Statements can be opinions. Whether something is a statement depends on if it is capable of being true or false.</mattext>
                </material>
              </response_label>
              <response_label ident="quiz2_q3_ans1">
                <material>
                  <mattext texttype="text/plain">Factory farming is a fact, not an opinion.</mattext>
                </material>
              </response_label>
              <response_label ident="quiz2_q3_ans2">
                <material>
                  <mattext texttype="text/plain">It is not a statement because it is a command.</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">quiz2_q3_ans0</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <item ident="quiz2_q4" title="Question 5">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;div&gt;What is wrong with this classification: 'There are an even number of stars in the Milky Way' is not a statement because no one knows whether it is true.&lt;/div&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="quiz2_q4_ans0">
                <material>
                  <mattext texttype="text/plain">A sentence can be a statement even if no one currently knows its truth value.</mattext>
                </material>
              </response_label>
              <response_label ident="quiz2_q4_ans1">
                <material>
                  <mattext texttype="text/plain">Astronomers do know the exact number of stars.</mattext>
                </material>
              </response_label>
              <response_label ident="quiz2_q4_ans2">
                <material>
                  <mattext texttype="text/plain">It is not a statement because it is an expression of feeling.</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">quiz2_q4_ans0</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
        </resprocessing>
      </item>
